---
/**
 * Layout — 全ページ共通の基本レイアウト(ヘッダーナビ + main + SiteFooter)。
 * docs/04-site-design.md 2節のページツリーに基づくナビゲーションを持つ。
 * ダーク/ライト切替は data-theme 属性 + localStorage の最小限JSで実装(dataviz/サイト方針: JS最小限)。
 *
 * @prop title - <title> に使うページタイトル(サイト名を末尾に付与)
 * @prop description - meta description(任意)
 * @prop lastUpdated - SiteFooter へ渡す最終更新時刻(ISO8601)
 * @prop dataSources - SiteFooter へ渡すデータ出典配列
 */
import SiteFooter from "../components/SiteFooter.astro";
import { withBase } from "../lib/url";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  lastUpdated?: string;
  dataSources?: string[];
}

const {
  title,
  description = "指標の寄与度で「基準を持った売買」へ。日米の株価指標を歴史的位置とエビデンスつきで毎日更新。",
  lastUpdated,
  dataSources,
} = Astro.props;

const currentPath = Astro.url.pathname;
/**
 * 現在ページ判定: トップは完全一致、それ以外は前方一致(配下ページでもナビに現在地を示す)。
 * Astro.url.pathname は base("/investsite/"等)込みの値を返すため、比較前に href 側にも
 * withBase() で base を前置してから比較する。
 */
function isCurrent(href: string): boolean {
  const prefixed = withBase(href);
  if (href === "/") return currentPath === prefixed;
  return currentPath === prefixed || currentPath.startsWith(prefixed);
}

const navItems = [
  { href: "/", label: "ダッシュボード" },
  { href: "/markets/jp/", label: "日本市場" },
  { href: "/markets/us/", label: "米国市場" },
  { href: "/factors/", label: "ファクター" },
  { href: "/screener/", label: "スクリーナー" },
  { href: "/learn/", label: "学ぶ" },
  { href: "/about/", label: "サイトについて" },
];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="icon" href={withBase("/favicon.ico")} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} | investsite</title>
    <script is:inline>
      // FOUC防止: レンダリング前に保存済みテーマを即時適用
      (function () {
        try {
          var saved = localStorage.getItem("investsite-theme");
          if (saved === "light" || saved === "dark") {
            document.documentElement.setAttribute("data-theme", saved);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">本文へスキップ</a>
    <header class="site-header">
      <div class="container site-header__inner">
        <a class="site-header__brand" href={withBase("/")}>investsite</a>
        <nav class="site-header__nav" aria-label="サイトナビゲーション">
          <ul>
            {navItems.map((item) => (
              <li>
                <a href={withBase(item.href)} aria-current={isCurrent(item.href) ? "page" : undefined}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
        <button
          type="button"
          id="theme-toggle"
          class="theme-toggle"
          aria-label="ダーク/ライト表示切替"
        >
          <span aria-hidden="true">🌓</span>
        </button>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <SiteFooter lastUpdated={lastUpdated} dataSources={dataSources} />

    <script is:inline>
      (function () {
        var btn = document.getElementById("theme-toggle");
        if (!btn) return;
        btn.addEventListener("click", function () {
          var current = document.documentElement.getAttribute("data-theme");
          var prefersDark =
            window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
          var currentEffective = current || (prefersDark ? "dark" : "light");
          var next = currentEffective === "dark" ? "light" : "dark";
          document.documentElement.setAttribute("data-theme", next);
          try {
            localStorage.setItem("investsite-theme", next);
          } catch (e) {}
        });
      })();
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    background: var(--surface-card);
    color: var(--text-primary);
    padding: var(--space-2) var(--space-3);
    z-index: 100;
  }

  .skip-link:focus {
    left: var(--space-2);
    top: var(--space-2);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--surface-card);
    border-bottom: 1px solid var(--border-gridline);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding-block: var(--space-3);
  }

  .site-header__brand {
    font-weight: 700;
    font-size: var(--font-size-lg);
    color: var(--text-primary);
    text-decoration: none;
    flex-shrink: 0;
  }

  .site-header__nav {
    flex: 1;
    overflow-x: auto;
  }

  .site-header__nav ul {
    display: flex;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
    white-space: nowrap;
  }

  .site-header__nav a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--font-size-sm);
  }

  .site-header__nav a:hover {
    color: var(--color-accent);
  }

  .site-header__nav a[aria-current="page"] {
    color: var(--text-primary);
    font-weight: 600;
    border-bottom: 2px solid var(--color-accent);
  }

  /* モバイル: ナビはハンバーガーを使わず横スクロールで全項目に到達可能とする(T-11方針)。
     タップ領域を確保するためリンクをブロック化し縦パディングを付与 */
  .site-header__nav a {
    display: inline-block;
    padding-block: var(--space-2);
  }

  .theme-toggle {
    flex-shrink: 0;
    background: transparent;
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-2);
    cursor: pointer;
    font-size: var(--font-size-base);
    color: var(--text-primary);
  }

  main {
    min-height: 60vh;
  }

  @media (max-width: 640px) {
    .site-header__inner {
      gap: var(--space-2);
    }

    .site-header__nav ul {
      gap: var(--space-3);
    }
  }
</style>
