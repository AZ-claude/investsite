---
/**
 * Logo — サイトのブランドマーク(アイコン+ワードマーク+ファミリータグ)。
 *
 * アイコンは PercentileBar.astro(歴史的位置バー)をそのままモチーフにしている。
 * 「現在値+歴史的位置」というサイトの核となる差別化コンセプト(docs/04-site-design.md 1節)を
 * そのまま視覚化することで、一般的な株価チャート/雄牛モチーフより製品との一体感を持たせる。
 * 色は currentColor / CSS変数を使うためページのテーマ(ライト/ダーク)に自動追従する。
 *
 * @prop withTag - "by Rakusetsu" ファミリータグを表示するか(既定: true)
 */
interface Props {
  withTag?: boolean;
}

const { withTag = true } = Astro.props;
---

<span class="logo">
  <svg class="logo__icon" viewBox="0 0 32 32" aria-hidden="true">
    <rect x="3" y="14" width="26" height="4" rx="2" class="logo__track" />
    <rect x="3" y="14" width="17" height="4" rx="2" class="logo__fill" />
    <circle cx="20" cy="16" r="4.5" class="logo__marker" />
  </svg>
  <span class="logo__text">
    <span class="logo__word">investsite</span>
    {withTag && <span class="logo__tag">by Rakusetsu</span>}
  </span>
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-primary);
    text-decoration: none;
  }

  .logo__icon {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }

  .logo__track {
    fill: var(--border-baseline);
  }

  .logo__fill {
    fill: var(--color-accent);
  }

  .logo__marker {
    fill: var(--color-accent);
    stroke: var(--surface-card);
    stroke-width: 2;
  }

  .logo__text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .logo__word {
    font-weight: 700;
    font-size: var(--font-size-lg);
    letter-spacing: -0.01em;
  }

  .logo__tag {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }
</style>
