---
/**
 * PercentileBar — 歴史的位置(パーセンタイル)の帯グラフ。
 * MetricCard の3点セットの一部として使うほか、市場体温計にも流用する(docs/04-site-design.md 4節)。
 *
 * 配色方針(dataviz スキル references/marks-and-anatomy.md「Meter」準拠):
 * 塗り(fill)が現在地、未塗り(track)は同ランプの淡色ステップ。severity ではなく
 * 「どこに位置するか」を表すため単一アクセント色(--percentile-fill)で統一する。
 *
 * @prop percentile - 0〜1の値。null の場合は「データ不足」を明示表示する(欠損を隠さない)
 * @prop label - バー上部のラベル(例: 「PBR 歴史的位置」)
 * @prop lowLabel / highLabel - 両端の意味ラベル(例: 「割安」「割高」)
 * @prop size - "sm" | "md"。カードに埋め込む場合は sm、市場体温計単体では md
 */
interface Props {
  percentile: number | null;
  label?: string;
  lowLabel?: string;
  highLabel?: string;
  size?: "sm" | "md";
}

const {
  percentile,
  label,
  lowLabel = "低い",
  highLabel = "高い",
  size = "sm",
} = Astro.props;

const hasValue = percentile !== null && percentile !== undefined && !Number.isNaN(percentile);
const clamped = hasValue ? Math.min(1, Math.max(0, percentile as number)) : 0;
const pct = Math.round(clamped * 1000) / 10; // 小数第1位まで
---

<div class:list={["percentile-bar", `percentile-bar--${size}`]}>
  {label && <div class="percentile-bar__label">{label}</div>}
  <div
    class="percentile-bar__track"
    role="img"
    aria-label={hasValue
      ? `${label ?? "歴史的位置"}: 過去分布の上位から見て${pct}パーセンタイル`
      : `${label ?? "歴史的位置"}: データ不足のため算出不可`}
  >
    {hasValue ? (
      <div class="percentile-bar__fill" style={`width:${pct}%`}>
        <span class="percentile-bar__marker" style="right:0"></span>
      </div>
    ) : (
      <div class="percentile-bar__empty">データ不足</div>
    )}
  </div>
  <div class="percentile-bar__scale">
    <span class="num">{lowLabel}</span>
    {hasValue && <span class="percentile-bar__value num">{pct}%ile</span>}
    <span class="num">{highLabel}</span>
  </div>
</div>

<style>
  .percentile-bar {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    width: 100%;
  }

  .percentile-bar__label {
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
  }

  .percentile-bar__track {
    position: relative;
    width: 100%;
    background: var(--percentile-track);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .percentile-bar--sm .percentile-bar__track {
    height: 8px;
  }

  .percentile-bar--md .percentile-bar__track {
    height: 16px;
  }

  .percentile-bar__fill {
    position: relative;
    height: 100%;
    background: var(--percentile-fill);
    border-radius: var(--radius-sm);
    min-width: 4px;
    transition: width 0.2s ease;
  }

  .percentile-bar__marker {
    position: absolute;
    top: 50%;
    transform: translate(50%, -50%);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--percentile-fill);
    border: 2px solid var(--surface-card);
  }

  .percentile-bar__empty {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    font-size: var(--font-size-xs);
    color: var(--text-muted);
  }

  .percentile-bar__scale {
    display: flex;
    justify-content: space-between;
    font-size: var(--font-size-xs);
    color: var(--text-muted);
  }

  .percentile-bar__value {
    color: var(--text-secondary);
    font-weight: 600;
  }
</style>
